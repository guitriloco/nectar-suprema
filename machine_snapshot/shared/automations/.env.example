# ============================================================
# CONFIGURAÇÃO DO SISTEMA DE AUTOMAÇÃO — Lista Quente
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais
# ============================================================

# --- KIWIFY ---
KIWIFY_API_KEY=seu_kiwify_api_key_aqui
KIWIFY_PRODUCT_ID=seu_product_id_aqui
KIWIFY_WEBHOOK_SECRET=seu_webhook_secret_aqui

# --- HOTMART ---
HOTMART_WEBHOOK_TOKEN=seu_hotmart_webhook_token_aqui
HOTMART_PRODUCT_ID=seu_hotmart_product_id_aqui
HOTMART_API_KEY=seu_hotmart_api_key_aqui

# --- RD STATION ---
RD_STATION_API_KEY=seu_rd_station_api_key_aqui
RD_STATION_WORKSPACE_UUID=seu_rd_station_workspace_uuid_aqui

# --- SMTP ---
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_smtp
SMTP_FROM=nome@seudominio.com
SMTP_FROM_NAME=Lista Quente

# --- RASTREAMENTO ---
FACEBOOK_PIXEL_ID=seu_facebook_pixel_id_aqui
FACEBOOK_ACCESS_TOKEN=seu_facebook_access_token_aqui
GA_MEASUREMENT_ID=seu_ga_measurement_id_aqui

# --- BANCO DE DADOS (se usar SQL para logs) ---
DB_HOST=localhost
DB_NAME=automations
DB_USER=automations_user
DB_PASS=sua_senha_db

# --- URL DO SITE ---
SITE_URL=https://www.seudominio.com
AREA_ALUNO_URL=https://www.seudominio.com/area-do-aluno
CHECKOUT_URL=https://www.seudominio.com/checkout